<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hinos</title>
  <link rel="stylesheet" href="/style.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
  <nav>
    <span class="brand">Hinos</span>
    <a href="/hinos" class="<%= path.startsWith('/hinos') ? 'active' : '' %>">Hinos</a>
    <a href="/cultos" class="<%= path.startsWith('/cultos') ? 'active' : '' %>">Cultos</a>
    <a href="/temas" class="<%= path.startsWith('/temas') ? 'active' : '' %>">Temas</a>
    <a href="/integracoes/planning-center" class="<%= path.startsWith('/integracoes/planning-center') ? 'active' : '' %>">Integrações</a>
    <a href="/integracoes/sync-logs" class="<%= path.startsWith('/integracoes/sync-logs') ? 'active' : '' %>">Logs de Sync</a>
    <span class="spacer"></span>
    <span class="nav-version">v <%= appVersion %></span>
    <form method="POST" action="/logout" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-secondary btn-sm">Sair</button>
    </form>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Hinos <span class="count-badge"><%= total %></span></h1>
      <div class="hymn-toolbar">
        <form method="GET" action="/hinos" class="hymn-search-inline">
          <input type="search" name="q" value="<%= q || '' %>" placeholder="Buscar por título, número, hinário..." class="hymn-search-input">
          <% if (themeId > 0) { %><input type="hidden" name="theme" value="<%= themeId %>"><% } %>
          <% if (hymnalCode) { %><input type="hidden" name="hymnal" value="<%= hymnalCode %>"><% } %>
          <button type="submit" class="btn btn-secondary btn-sm">Buscar</button>
        </form>
        <a href="/hinos/novo" class="btn btn-primary">+ Adicionar Hino</a>
      </div>
    </div>

    <div class="filter-pills library-filter">
      <a href="<%= buildListUrl({ hymnal: '', page: 1 }) %>" class="<%= hymnalCode ? '' : 'active' %>">Todos</a>
      <% hymnals.forEach(function(hy) { %>
        <a href="<%= buildListUrl({ hymnal: hy.code, page: 1 }) %>" class="<%= hymnalCode === hy.code ? 'active' : '' %>"><%= hy.code %></a>
      <% }); %>
    </div>

    <form method="GET" action="/hinos" class="hymn-secondary-filters card">
      <div class="hymn-secondary-grid">
        <div class="form-group">
          <label for="hymn-theme-filter">Tema (opcional)</label>
          <select id="hymn-theme-filter" name="theme">
            <option value="">Todos os temas</option>
            <% themes.forEach(function(t) { %>
              <option value="<%= t.id %>" <%= themeId === t.id ? 'selected' : '' %>><%= t.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>&nbsp;</label>
          <div class="form-actions">
            <button type="submit" class="btn btn-secondary btn-sm">Aplicar Filtros</button>
            <a href="/hinos" class="btn btn-sm">Limpar</a>
          </div>
        </div>
      </div>
      <% if (q) { %><input type="hidden" name="q" value="<%= q %>"><% } %>
      <% if (hymnalCode) { %><input type="hidden" name="hymnal" value="<%= hymnalCode %>"><% } %>
    </form>

    <div class="list-meta">
      <% if (total > 0) { %>
        Mostrando <strong><%= ((page - 1) * pageSize) + 1 %>-<%= Math.min(page * pageSize, total) %></strong> de <strong><%= total %></strong> hinos.
      <% } else { %>
        Nenhum hino encontrado para os filtros atuais.
      <% } %>
    </div>

    <% if (hymns.length === 0) { %>
      <div class="card">
        <p class="empty-msg">
          <% if (q || hymnalCode || themeId > 0) { %>
            Nenhum hino corresponde aos filtros. <a href="/hinos">Ver todos</a>.
          <% } else { %>
            Nenhum hino cadastrado ainda. <a href="/hinos/novo">Adicionar primeiro hino</a>.
          <% } %>
        </p>
      </div>
    <% } else { %>
      <div class="card card-table">
        <table>
          <thead>
            <tr>
              <th style="width:60px">Hinário</th>
              <th style="width:50px">#</th>
              <th>Título</th>
              <th>Temas</th>
              <th style="width:110px">Último Uso</th>
              <th style="width:170px"></th>
            </tr>
          </thead>
          <tbody>
            <% hymns.forEach(function(h) { %>
              <tr>
                <td><span class="badge badge-<%= h.hymnal.toLowerCase() %>"><%= h.hymnal %></span></td>
                <td class="td-num"><%= h.number %></td>
                <td>
                  <a href="/hinos/<%= h.id %>/editar" class="hymn-title"><%= h.title %></a>
                  <% if (h.english_title) { %>
                    <div class="english-title"><%= h.english_title %></div>
                  <% } %>
                </td>
                <td class="td-themes"><%= h.themes || '' %></td>
                <td>
                  <% if (h.last_used) { %>
                    <span class="last-used"><%= h.last_used %></span>
                  <% } else { %>
                    <span class="never-used">nunca</span>
                  <% } %>
                </td>
                <td class="td-actions">
                  <button
                    type="button"
                    class="btn btn-primary btn-sm js-add-to-culto"
                    data-hymn-id="<%= h.id %>"
                    data-hymn-title="<%= h.hymnal %> <%= h.number %> — <%= h.title %>">
                    + Culto
                  </button>
                  <a href="/hinos/<%= h.id %>/editar" class="btn btn-secondary btn-sm">Editar</a>
                  <button class="btn btn-danger btn-sm" onclick="deleteHymn(<%= h.id %>, this)">×</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (pageCount > 1) { %>
        <div class="pagination-wrap">
          <a class="btn btn-sm <%= page <= 1 ? 'btn-disabled' : '' %>" href="<%= page <= 1 ? '#' : buildListUrl({ page: page - 1 }) %>">← Anterior</a>
          <% pageItems.forEach(function(pn) { %>
            <a class="btn btn-sm <%= pn === page ? 'btn-primary' : '' %>" href="<%= buildListUrl({ page: pn }) %>"><%= pn %></a>
          <% }); %>
          <a class="btn btn-sm <%= page >= pageCount ? 'btn-disabled' : '' %>" href="<%= page >= pageCount ? '#' : buildListUrl({ page: page + 1 }) %>">Próxima →</a>
        </div>
      <% } %>
    <% } %>
  </div>

  <div id="add-to-culto-modal" class="simple-modal-backdrop" style="display:none">
    <div class="simple-modal">
      <div class="simple-modal-title">Adicionar hino ao culto</div>
      <p id="add-to-culto-selected" class="simple-modal-sub"></p>

      <div class="form-group">
        <label for="add-to-culto-target">Playlist/Culto de destino</label>
        <select id="add-to-culto-target">
          <option value="">Escolha um culto</option>
          <option value="__new__">+ Criar novo culto</option>
          <% (cultoOptions || []).forEach(function(svc) { %>
            <option value="<%= svc.id %>">
              <%= svc.service_date %> — <%= SERVICE_LABELS[svc.service_type] || svc.service_type %> (<%= svc.hymn_count || 0 %>/5)<%= svc.notes ? (' — ' + svc.notes) : '' %>
            </option>
          <% }); %>
        </select>
      </div>

      <div id="add-to-culto-new-fields" style="display:none">
        <div class="form-row">
          <div class="form-group">
            <label for="add-to-culto-date">Data</label>
            <input id="add-to-culto-date" type="date" value="<%= nextSunday || '' %>">
          </div>
          <div class="form-group">
            <label for="add-to-culto-type">Tipo</label>
            <select id="add-to-culto-type">
              <option value="dom_manha">Domingo Manhã</option>
              <option value="dom_noite">Domingo Noite</option>
              <option value="qua">Quarta-Feira</option>
              <option value="especial">Culto Especial</option>
            </select>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <button type="button" id="add-to-culto-submit" class="btn btn-primary">Adicionar</button>
        <button type="button" id="add-to-culto-cancel" class="btn btn-secondary">Cancelar</button>
      </div>
    </div>
  </div>

  <script>
    const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
    let pendingAddHymnId = 0;
    let pendingAddHymnLabel = '';

    async function deleteHymn(id, btn) {
      if (!confirm('Excluir este hino? Esta ação não pode ser desfeita.')) return;
      btn.disabled = true;
      var res = await fetch('/api/hinos/' + id + '/delete', {
        method: 'POST',
        headers: { 'x-csrf-token': csrfToken },
      });
      if ((await res.json()).success) {
        btn.closest('tr').remove();
      } else {
        alert('Erro ao excluir.');
        btn.disabled = false;
      }
    }

    function openAddToCultoModal(hymnId, hymnLabel) {
      pendingAddHymnId = Number(hymnId) || 0;
      pendingAddHymnLabel = String(hymnLabel || '');
      document.getElementById('add-to-culto-selected').textContent = pendingAddHymnLabel;
      document.getElementById('add-to-culto-target').value = '';
      document.getElementById('add-to-culto-new-fields').style.display = 'none';
      document.getElementById('add-to-culto-modal').style.display = 'flex';
    }

    function closeAddToCultoModal() {
      document.getElementById('add-to-culto-modal').style.display = 'none';
      pendingAddHymnId = 0;
      pendingAddHymnLabel = '';
    }

    async function submitAddToCulto() {
      if (!pendingAddHymnId) return;
      const target = String(document.getElementById('add-to-culto-target').value || '').trim();
      if (!target) {
        alert('Escolha um culto de destino.');
        return;
      }

      const payload = {};
      if (target === '__new__') {
        const date = String(document.getElementById('add-to-culto-date').value || '').trim();
        const type = String(document.getElementById('add-to-culto-type').value || '').trim();
        if (!date || !type) {
          alert('Preencha data e tipo para criar o culto.');
          return;
        }
        payload.serviceDate = date;
        payload.serviceType = type;
      } else {
        payload.serviceId = target;
      }

      const res = await fetch('/api/hinos/' + pendingAddHymnId + '/add-to-culto', {
        method: 'POST',
        headers: {
          'x-csrf-token': csrfToken,
          'content-type': 'application/json',
        },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok || !body.success) {
        const code = String(body.error || 'UNKNOWN_ERROR');
        if (code === 'SERVICE_FULL') {
          alert('Esse culto já tem 5 hinos. Escolha outro ou edite o culto.');
          return;
        }
        alert('Não foi possível adicionar. Erro: ' + code);
        return;
      }

      if (body.status === 'already') {
        alert('Esse hino já está nesse culto.');
      } else {
        const slot = body.position ? (' (slot ' + body.position + ')') : '';
        alert('Hino adicionado com sucesso' + slot + '.');
      }
      closeAddToCultoModal();
    }

    document.querySelectorAll('.js-add-to-culto').forEach(function(btn) {
      btn.addEventListener('click', function() {
        openAddToCultoModal(btn.dataset.hymnId, btn.dataset.hymnTitle);
      });
    });

    document.getElementById('add-to-culto-target').addEventListener('change', function() {
      const show = this.value === '__new__';
      document.getElementById('add-to-culto-new-fields').style.display = show ? '' : 'none';
    });
    document.getElementById('add-to-culto-submit').addEventListener('click', function() {
      submitAddToCulto().catch(function() {
        alert('Erro inesperado ao adicionar hino ao culto.');
      });
    });
    document.getElementById('add-to-culto-cancel').addEventListener('click', closeAddToCultoModal);
    document.getElementById('add-to-culto-modal').addEventListener('click', function(e) {
      if (e.target === this) closeAddToCultoModal();
    });
  </script>
</body>
</html>
