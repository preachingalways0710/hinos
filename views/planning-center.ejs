<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Integrações</title>
  <link rel="stylesheet" href="/style.css?v=<%= appVersion %>">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
  <nav>
    <span class="brand">Hinos</span>
    <a href="/hinos" class="<%= path.startsWith('/hinos') ? 'active' : '' %>">Hinos</a>
    <a href="/cultos" class="<%= path.startsWith('/cultos') ? 'active' : '' %>">Cultos</a>
    <a href="/temas" class="<%= path.startsWith('/temas') ? 'active' : '' %>">Temas</a>
    <a href="/integracoes/planning-center" class="<%= path.startsWith('/integracoes/planning-center') ? 'active' : '' %>">Integrações</a>
    <a href="/integracoes/sync-logs" class="<%= path.startsWith('/integracoes/sync-logs') ? 'active' : '' %>">Logs de Sync</a>
    <span class="spacer"></span>
    <span class="nav-version">v <%= appVersion %></span>
    <form method="POST" action="/logout" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-secondary btn-sm">Sair</button>
    </form>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Integrações e Planejamento</h1>
      <a href="/cultos" class="btn btn-secondary">← Voltar para Cultos</a>
    </div>

    <div class="card">
      <h2 class="card-title">Planejamento Simples (Recomendado)</h2>
      <p class="form-hint" style="margin-bottom:.85rem">
        Para voluntários: trate cada culto como uma playlist. Crie novo ou abra um existente e comece a buscar/adicionar hinos.
      </p>

      <div class="form-actions" style="flex-wrap:wrap">
        <a href="/cultos/novo" class="btn btn-primary">Criar novo plano (playlist)</a>
        <a href="/cultos" class="btn btn-secondary">Ver todos os planos</a>
      </div>

      <% if (recentServices && recentServices.length) { %>
        <div class="form-row" style="margin-top:1rem">
          <div class="form-group">
            <label for="quick-existing-service">Abrir plano existente</label>
            <select id="quick-existing-service">
              <option value="">Selecione um culto...</option>
              <% recentServices.forEach(function(svc) { %>
                <option value="<%= svc.id %>">
                  <%= svc.service_date %> — <%= svc.playlist_name || 'Sem playlist' %><%= svc.notes ? (' — ' + svc.notes) : '' %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>&nbsp;</label>
            <div class="form-actions">
              <button id="quick-open-existing" class="btn btn-secondary" type="button" disabled>Abrir selecionado</button>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <h2 class="card-title">Planning Center (Avançado)</h2>

      <div class="pc-status-row">
        <div>
          <strong>Status:</strong>
          <span id="pc-status-text">
            <% if (!status.configured) { %>
              Não configurado no servidor
            <% } else if (!status.connected) { %>
              Configurado, mas desconectado
            <% } else { %>
              Conectado <%= status.profile && status.profile.name ? ('como ' + status.profile.name) : '' %>
            <% } %>
          </span>
        </div>
        <div class="pc-status-hints">
          <% if (!status.encryptedAtRest) { %>
            <span class="badge badge-warn">Tokens sem criptografia em repouso (defina APP_ENCRYPTION_KEY)</span>
          <% } %>
          <% if (status.importedAt) { %>
            <span class="badge badge-info">Último import: <%= status.importedAt %></span>
          <% } %>
        </div>
      </div>

      <% if (status.configured) { %>
        <div class="pc-auth-actions">
          <% if (!status.connected) { %>
            <form method="POST" action="/integracoes/planning-center/connect">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-primary">Conectar conta</button>
            </form>
          <% } else { %>
            <form method="POST" action="/integracoes/planning-center/disconnect">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-secondary">Desconectar conta</button>
            </form>
          <% } %>
        </div>
      <% } %>

      <% if (!status.configured) { %>
        <div class="alert alert-warn" style="margin-top:.8rem">
          Integração PCO não configurada. Defina no servidor: <code>PCO_CLIENT_ID</code>, <code>PCO_CLIENT_SECRET</code> e <code>PCO_REDIRECT_URI</code>.
          Enquanto isso, use o <strong>Planejamento Simples</strong> acima.
        </div>
      <% } %>
    </div>

    <% if (status.configured && status.connected) { %>
      <div class="card">
        <h2 class="card-title">Importar Plano do Planning Center</h2>
        <div id="pc-message" class="form-hint">Selecione tipo de serviço e plano para gerar prévia.</div>

        <div class="form-row">
          <div class="form-group">
            <label for="pc-service-type">Tipo de serviço (Planning Center)</label>
            <select id="pc-service-type">
              <option value="">Carregando...</option>
            </select>
          </div>
          <div class="form-group">
            <label for="pc-plan">Plano</label>
            <select id="pc-plan">
              <option value="">Selecione um tipo de serviço</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="pc-tolerance">Tolerância de correspondência</label>
            <select id="pc-tolerance">
              <option value="strict">Rigorosa</option>
              <option value="balanced" selected>Equilibrada</option>
              <option value="aggressive">Agressiva</option>
            </select>
          </div>
          <div class="form-group">
            <label for="pc-import-mode">Modo de importação</label>
            <select id="pc-import-mode">
              <option value="append" selected>Adicionar ao culto</option>
              <option value="replace">Substituir culto</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="pc-local-date">Data do culto no Hinos</label>
            <input type="date" id="pc-local-date">
          </div>
          <div class="form-group">
            <label for="pc-local-playlist">Playlist no App (Promidia)</label>
            <input type="text" id="pc-local-playlist" list="pc-local-playlist-list" placeholder="Ex: APELO, CEIA...">
            <datalist id="pc-local-playlist-list">
              <% const seenPcPlaylists = new Set(); %>
              <% (promidiaPlaylistNames || []).forEach(function(name) { %>
                <% const safeName = String(name || '').trim(); %>
                <% if (!safeName || seenPcPlaylists.has(safeName)) return; %>
                <% seenPcPlaylists.add(safeName); %>
                <option value="<%= safeName %>"></option>
              <% }); %>
              <% (recentServices || []).forEach(function(svc) { %>
                <% const safeName = String(svc && svc.playlist_name || '').trim(); %>
                <% if (!safeName || seenPcPlaylists.has(safeName)) return; %>
                <% seenPcPlaylists.add(safeName); %>
                <option value="<%= safeName %>"></option>
              <% }); %>
            </datalist>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="pc-max-slots">Máximo de hinos (limite atual: 5)</label>
            <input type="number" id="pc-max-slots" min="1" max="5" value="5">
          </div>
          <div class="form-group">
            <label>&nbsp;</label>
            <div class="form-actions">
              <button id="pc-preview-btn" class="btn btn-secondary" type="button">Gerar prévia</button>
              <button id="pc-import-btn" class="btn btn-primary" type="button" disabled>Importar para cultos</button>
            </div>
          </div>
        </div>

        <div class="pc-summary" id="pc-summary">Sem prévia.</div>
        <div class="pc-preview-wrap">
          <table id="pc-preview-table">
            <thead>
              <tr>
                <th style="width:60px">#</th>
                <th>Item</th>
                <th style="width:110px">Tipo</th>
                <th style="width:120px">Status</th>
                <th>Correspondência</th>
              </tr>
            </thead>
            <tbody>
              <tr><td colspan="5" class="muted">Nenhuma prévia carregada.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <h2 class="card-title">Importar Plano do Planning Center</h2>
        <p class="empty-msg" style="padding:0">
          Esta seção fica disponível quando a integração PCO estiver configurada e conectada.
          Use o <strong>Planejamento Simples</strong> acima para montar cultos agora.
        </p>
      </div>
    <% } %>
  </div>

  <script>
    const quickSelectEl = document.getElementById('quick-existing-service');
    const quickOpenBtn = document.getElementById('quick-open-existing');
    if (quickSelectEl && quickOpenBtn) {
      quickSelectEl.addEventListener('change', () => {
        quickOpenBtn.disabled = !quickSelectEl.value;
      });
      quickOpenBtn.addEventListener('click', () => {
        if (!quickSelectEl.value) return;
        window.location.href = '/cultos/' + encodeURIComponent(quickSelectEl.value) + '/editar';
      });
    }

    const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
    const status = <%- JSON.stringify(status || {}) %>;
    let previewPayload = null;

    const messageEl = document.getElementById('pc-message');
    const summaryEl = document.getElementById('pc-summary');
    const serviceTypeEl = document.getElementById('pc-service-type');
    const planEl = document.getElementById('pc-plan');
    const toleranceEl = document.getElementById('pc-tolerance');
    const importModeEl = document.getElementById('pc-import-mode');
    const localDateEl = document.getElementById('pc-local-date');
    const localPlaylistEl = document.getElementById('pc-local-playlist');
    const maxSlotsEl = document.getElementById('pc-max-slots');
    const previewBtn = document.getElementById('pc-preview-btn');
    const importBtn = document.getElementById('pc-import-btn');
    const tableBody = document.querySelector('#pc-preview-table tbody');

    function setMessage(msg) {
      if (!messageEl) return;
      messageEl.textContent = msg || '';
    }

    function statusBadge(statusValue) {
      if (statusValue === 'matched') return '<span class="badge badge-ok">correspondido</span>';
      if (statusValue === 'ambiguous') return '<span class="badge badge-warn">ambíguo</span>';
      return '<span class="badge badge-error">não encontrado</span>';
    }

    function renderPreview(preview) {
      if (!importBtn || !summaryEl || !tableBody) return;
      previewPayload = preview;
      importBtn.disabled = !preview;
      if (!preview || !Array.isArray(preview.items) || !preview.items.length) {
        summaryEl.textContent = 'Sem prévia.';
        tableBody.innerHTML = '<tr><td colspan="5" class="muted">Nenhuma prévia carregada.</td></tr>';
        return;
      }
      const summary = preview.summary || {};
      summaryEl.textContent = `Total: ${summary.total || 0} | correspondidos: ${summary.matched || 0} | ambíguos: ${summary.ambiguous || 0} | não encontrados: ${summary.unmatched || 0}`;
      tableBody.innerHTML = preview.items.map(item => {
        const match = item.match || {};
        const top = (match.candidates || [])[0];
        const label = match.hymnId
          ? `${top && top.hymnTitle ? top.hymnTitle : 'ID ' + match.hymnId} (conf ${match.confidence || 0})`
          : (top && top.hymnTitle ? `${top.hymnTitle} (conf ${top.confidence || 0})` : 'Sem candidato');
        return `
          <tr>
            <td>${item.sequence || ''}</td>
            <td>${item.title || ''}</td>
            <td>${item.itemType || ''}</td>
            <td>${statusBadge(match.status || 'unmatched')}</td>
            <td>${label}</td>
          </tr>
        `;
      }).join('');
    }

    async function getJson(url) {
      const res = await fetch(url, {
        headers: {
          'Accept': 'application/json',
          'x-csrf-token': csrfToken,
        },
      });
      return res.json();
    }

    async function postJson(url, payload) {
      const res = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'x-csrf-token': csrfToken,
        },
        body: JSON.stringify(payload || {}),
      });
      return res.json();
    }

    async function loadServiceTypes() {
      if (!serviceTypeEl || !planEl) return;
      if (!status.connected) {
        serviceTypeEl.innerHTML = '<option value="">Conecte sua conta primeiro</option>';
        planEl.innerHTML = '<option value="">Conecte sua conta primeiro</option>';
        return;
      }
      const response = await getJson('/api/planning-center/service-types');
      if (!response.ok) throw new Error(response.error || 'Falha ao carregar tipos de serviço.');
      const rows = response.serviceTypes || [];
      if (!rows.length) {
        serviceTypeEl.innerHTML = '<option value="">Nenhum tipo de serviço encontrado</option>';
        return;
      }
      serviceTypeEl.innerHTML = rows.map(row => `<option value="${row.id}">${row.name}</option>`).join('');
      await loadPlans();
    }

    async function loadPlans() {
      if (!serviceTypeEl || !planEl) return;
      const serviceTypeId = serviceTypeEl.value;
      if (!serviceTypeId) {
        planEl.innerHTML = '<option value="">Selecione um tipo de serviço</option>';
        return;
      }
      const response = await getJson('/api/planning-center/plans?serviceTypeId=' + encodeURIComponent(serviceTypeId));
      if (!response.ok) throw new Error(response.error || 'Falha ao carregar planos.');
      const rows = response.plans || [];
      if (!rows.length) {
        planEl.innerHTML = '<option value="">Nenhum plano encontrado</option>';
        return;
      }
      planEl.innerHTML = rows.map(row => {
        const label = row.shortDates ? `${row.shortDates} — ${row.title}` : row.title;
        return `<option value="${row.id}">${label}</option>`;
      }).join('');
    }

    if (serviceTypeEl && planEl && previewBtn && importBtn) {
      serviceTypeEl.addEventListener('change', async () => {
        try {
          await loadPlans();
          renderPreview(null);
        } catch (err) {
          setMessage(err.message || 'Erro ao carregar planos.');
        }
      });

      previewBtn.addEventListener('click', async () => {
        try {
          const serviceTypeId = serviceTypeEl.value;
          const planId = planEl.value;
          if (!serviceTypeId || !planId) {
            setMessage('Selecione tipo de serviço e plano.');
            return;
          }
          setMessage('Gerando prévia...');
          const response = await getJson(
            '/api/planning-center/preview?serviceTypeId=' + encodeURIComponent(serviceTypeId)
            + '&planId=' + encodeURIComponent(planId)
            + '&tolerance=' + encodeURIComponent(toleranceEl.value)
          );
          if (!response.ok) throw new Error(response.error || 'Falha na prévia.');
          renderPreview(response.preview);
          if (response.preview && response.preview.planDate && !localDateEl.value) {
            localDateEl.value = String(response.preview.planDate).slice(0, 10);
          }
          if (response.preview && response.preview.planTitle && localPlaylistEl && !localPlaylistEl.value) {
            localPlaylistEl.value = String(response.preview.planTitle);
          }
          setMessage('Prévia pronta.');
        } catch (err) {
          setMessage(err.message || 'Erro ao gerar prévia.');
        }
      });

      importBtn.addEventListener('click', async () => {
        try {
          if (!previewPayload) {
            setMessage('Gere a prévia antes de importar.');
            return;
          }
          if (!localDateEl.value || !localPlaylistEl.value) {
            setMessage('Defina data e playlist no Hinos.');
            return;
          }
          if (importModeEl.value === 'replace') {
            if (!confirm('Substituir culto existente para essa data/playlist (se houver)?')) return;
          }
          setMessage('Importando...');
          const response = await postJson('/api/planning-center/import', {
            serviceTypeId: serviceTypeEl.value,
            planId: planEl.value,
            tolerance: toleranceEl.value,
            localDate: localDateEl.value,
            localPlaylistName: localPlaylistEl.value,
            importMode: importModeEl.value,
            maxSlots: Number(maxSlotsEl.value || 5),
          });
          if (!response.ok) throw new Error(response.error || 'Falha na importação.');
          setMessage(`Importado com sucesso: ${response.result.importedCount} hino(s).`);
        } catch (err) {
          setMessage(err.message || 'Erro ao importar.');
        }
      });

      (async () => {
        try {
          await loadServiceTypes();
        } catch (err) {
          setMessage(err.message || 'Falha ao inicializar integração.');
        }
      })();
    }
  </script>
</body>
</html>
