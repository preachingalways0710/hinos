<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logs de Sync</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <span class="brand">Hinos</span>
    <a href="/hinos" class="<%= path.startsWith('/hinos') ? 'active' : '' %>">Hinos</a>
    <a href="/cultos" class="<%= path.startsWith('/cultos') ? 'active' : '' %>">Cultos</a>
    <a href="/temas" class="<%= path.startsWith('/temas') ? 'active' : '' %>">Temas</a>
    <a href="/integracoes/planning-center" class="<%= path.startsWith('/integracoes/planning-center') ? 'active' : '' %>">Integrações</a>
    <a href="/integracoes/sync-logs" class="<%= path.startsWith('/integracoes/sync-logs') ? 'active' : '' %>">Logs de Sync</a>
    <span class="spacer"></span>
    <span class="nav-version">v <%= appVersion %></span>
    <form method="POST" action="/logout" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-secondary btn-sm">Sair</button>
    </form>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Promidia Sync Logs</h1>
      <a href="/integracoes/planning-center" class="btn btn-secondary">← Integrações</a>
    </div>

    <div class="card">
      <h2 class="card-title">Conectar Promidia (setup rápido)</h2>
      <div class="pc-status-hints" style="margin-bottom:.75rem">
        <% if (syncAuth && syncAuth.envConfigured) { %>
          <span class="badge badge-info">Token por ENV ativo</span>
        <% } %>
        <% if (syncAuth && syncAuth.managedConfigured) { %>
          <span class="badge badge-ok">Token gerenciado ativo</span>
        <% } else { %>
          <span class="badge badge-warn">Token gerenciado ausente</span>
        <% } %>
      </div>

      <% if (syncAuth && syncAuth.envConfigured) { %>
        <div class="alert alert-warn">
          Token por <code>.env</code> detectado. Ele tem prioridade sobre token gerenciado pela tela.
        </div>
      <% } %>

      <div class="form-group">
        <label>Endpoint para colar no Promidia</label>
        <div class="sync-inline-copy">
          <input id="sync-endpoint" type="text" readonly value="<%= endpoint %>">
          <button type="button" class="btn btn-secondary btn-sm" data-copy-target="sync-endpoint">Copiar</button>
        </div>
      </div>

      <div class="form-actions">
        <form method="POST" action="/integracoes/sync-token/regenerate">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-primary">Gerar novo token</button>
        </form>
        <form method="POST" action="/integracoes/sync-token/clear">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-secondary">Remover token gerenciado</button>
        </form>
      </div>

      <% if (syncAuth && syncAuth.managedConfigured && syncAuth.managedTokenPrefix) { %>
        <p class="form-hint">Token atual: <code><%= syncAuth.managedTokenPrefix %>******</code> <%= syncAuth.managedUpdatedAt ? ('(atualizado em ' + syncAuth.managedUpdatedAt + ')') : '' %></p>
      <% } %>

      <% if (oneTimeToken) { %>
        <div class="sync-token-box">
          <div class="sync-token-title">Novo token (mostrado só agora)</div>
          <div class="sync-inline-copy">
            <input id="sync-token-once" type="text" readonly value="<%= oneTimeToken %>">
            <button type="button" class="btn btn-secondary btn-sm" data-copy-target="sync-token-once">Copiar</button>
          </div>
          <div class="form-hint">Cole no Promidia em: <strong>Sync Site → Sync Token</strong>.</div>
        </div>
      <% } %>
    </div>

    <div class="card card-table">
      <% if (!logs || logs.length === 0) { %>
        <div class="empty-msg" style="padding:1rem">Nenhum sync registrado ainda.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th style="width:160px">Quando</th>
              <th style="width:90px">Status</th>
              <th style="width:80px">Recv</th>
              <th style="width:80px">Proc</th>
              <th style="width:80px">Created</th>
              <th style="width:80px">Updated</th>
              <th style="width:90px">Unchanged</th>
              <th style="width:80px">Dropped</th>
              <th style="width:90px">Theme+</th>
              <th>Detalhes</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(row) { %>
              <tr>
                <td class="td-date"><%= row.createdAt %></td>
                <td>
                  <% if (row.status === 'success') { %>
                    <span class="badge badge-ok">success</span>
                  <% } else { %>
                    <span class="badge badge-error">error</span>
                  <% } %>
                </td>
                <td><%= row.received %></td>
                <td><%= row.processed %></td>
                <td><%= row.created %></td>
                <td><%= row.updated %></td>
                <td><%= row.unchanged %></td>
                <td><%= row.dropped %></td>
                <td><%= row.themedLinks %></td>
                <td>
                  <% if (row.status === 'error') { %>
                    <span class="never-used"><%= row.errorCode || 'sync_failed' %></span>
                  <% } else { %>
                    <span class="muted"><%= row.details && row.details.sourceVersion ? ('Promidia ' + row.details.sourceVersion) : '—' %></span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <script>
    async function copyFromInput(targetId) {
      const input = document.getElementById(targetId);
      if (!input) return;
      const value = input.value || '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        input.focus();
        input.select();
        document.execCommand('copy');
      }
    }

    document.querySelectorAll('[data-copy-target]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const target = btn.getAttribute('data-copy-target');
        await copyFromInput(target);
        const old = btn.textContent;
        btn.textContent = 'Copiado';
        setTimeout(() => { btn.textContent = old; }, 1200);
      });
    });
  </script>
</body>
</html>
