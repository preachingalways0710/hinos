<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= service ? 'Editar Culto' : 'Planejar Culto' %></title>
  <link rel="stylesheet" href="/style.css?v=<%= appVersion %>">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
  <nav>
    <span class="brand">Hinos</span>
    <a href="/hinos">Hinos</a>
    <a href="/cultos" class="active">Cultos</a>
    <a href="/temas">Temas</a>
    <a href="/integracoes/planning-center">Integrações</a>
    <a href="/integracoes/sync-logs" class="<%= path.startsWith('/integracoes/sync-logs') ? 'active' : '' %>">Logs de Sync</a>
    <span class="spacer"></span>
    <span class="nav-version">v <%= appVersion %></span>
    <form method="POST" action="/logout" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-secondary btn-sm">Sair</button>
    </form>
  </nav>

  <div class="container planner-page">
    <% const isEditMode = !!(service && service.id); %>
    <% const seed = formSeed || {}; %>
    <% const currentDate = isEditMode ? service.service_date : (seed.service_date || ''); %>
    <% const currentPlaylistName = isEditMode ? (service.playlist_name || '') : (seed.playlist_name || ''); %>
    <% const currentNotes = isEditMode ? (service.notes || '') : (seed.notes || ''); %>
    <div class="page-header">
      <h1><%= service ? 'Editar Culto' : 'Planejar Culto' %></h1>
      <a href="/cultos" class="btn btn-secondary">← Voltar</a>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="<%= isEditMode ? '/cultos/' + service.id + '/atualizar' : '/cultos' %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (!isEditMode) { %>
          <input type="hidden" name="base_template" id="base_template" value="<%= sourceTemplateKey || '' %>">
        <% } %>

        <% if (!isEditMode) { %>
          <div class="form-group">
            <label for="base-template-select">Basear em plano existente <span class="label-optional">(opcional)</span></label>
            <select id="base-template-select">
              <option value="">Começar do zero</option>
              <% if ((templateServices || []).length) { %>
                <optgroup label="Cultos existentes">
                  <% (templateServices || []).forEach(function(t) { %>
                    <% var key = 'local:' + t.id; %>
                    <option value="<%= key %>" <%= (sourceTemplateKey || '') === key ? 'selected' : '' %>>
                      <%= t.service_date %> — <%= t.playlist_name || 'Sem playlist' %> (<%= t.hymn_count || 0 %> hinos)<%= t.notes ? (' — ' + t.notes) : '' %>
                    </option>
                  <% }); %>
                </optgroup>
              <% } %>
              <% if ((templatePromidiaPlaylists || []).length) { %>
                <optgroup label="Playlists sincronizadas (Promidia)">
                  <% (templatePromidiaPlaylists || []).forEach(function(t) { %>
                    <% var key = 'promidia:' + t.external_playlist_id; %>
                    <option value="<%= key %>" <%= (sourceTemplateKey || '') === key ? 'selected' : '' %>>
                      <%= t.name %> (<%= t.item_count || 0 %> itens)<%= t.updated_at ? (' — sync ' + t.updated_at) : '' %>
                    </option>
                  <% }); %>
                </optgroup>
              <% } %>
            </select>
            <p class="form-hint">Escolha um plano para copiar os hinos e a playlist, depois ajuste a data.</p>
          </div>
        <% } %>

        <div class="planner-grid">
          <div class="planner-main">
            <div class="form-group">
              <label for="service_date">Data</label>
              <input type="date" id="service_date" name="service_date"
                value="<%= currentDate %>" required>
            </div>

            <div class="form-group">
              <label for="playlist_name">Playlist no App (Promidia)</label>
              <input type="text" id="playlist_name" name="playlist_name" list="playlist-name-options"
                value="<%= currentPlaylistName %>"
                placeholder="Ex: APELO, DOMINGO MANHÃ, CEIA..." required>
              <datalist id="playlist-name-options">
                <% const seenPlaylistNames = new Set(); %>
                <% (templatePromidiaPlaylists || []).forEach(function(t) { %>
                  <% const pName = String(t && t.name || '').trim(); %>
                  <% if (!pName || seenPlaylistNames.has(pName)) return; %>
                  <% seenPlaylistNames.add(pName); %>
                    <option value="<%= pName %>"></option>
                <% }); %>
                <% (templateServices || []).forEach(function(t) { %>
                  <% const pName = String(t && t.playlist_name || '').trim(); %>
                  <% if (!pName || seenPlaylistNames.has(pName)) return; %>
                  <% seenPlaylistNames.add(pName); %>
                  <option value="<%= pName %>"></option>
                <% }); %>
              </datalist>
              <p class="form-hint">Este nome deve bater com a playlist real usada no Promidia app.</p>
            </div>

            <div class="form-group">
              <label for="notes">Observações <span class="label-optional">(opcional)</span></label>
              <input type="text" id="notes" name="notes"
                value="<%= currentNotes %>"
                placeholder="ex: Culto de missões, visitantes especiais...">
            </div>

            <div class="form-group">
              <label>Hinos <span class="label-optional">(até 5)</span></label>
              <div class="slots">
                <% [1,2,3,4,5].forEach(function(n) { %>
                  <div class="slot" data-slot="<%= n %>">
                    <div class="slot-num"><%= n %></div>
                    <div class="slot-body">
                      <input type="text" id="search-<%= n %>" placeholder="Buscar por título ou número..." autocomplete="off">
                      <ul class="hymn-dropdown" id="dropdown-<%= n %>"></ul>
                      <span class="slot-selected" id="selected-<%= n %>" style="display:none"></span>
                    </div>
                    <button type="button" class="slot-clear" id="clear-<%= n %>" style="display:none" title="Remover">×</button>
                    <input type="hidden" name="hymn_ids" id="hymn-id-<%= n %>" value="">
                  </div>
                <% }); %>
              </div>
              <p class="form-hint">Clique em um slot para selecionar destino. Você também pode usar o navegador de hinos ao lado.</p>
            </div>
          </div>

          <aside class="planner-browser">
            <div class="planner-browser-header">
              <h2>Navegar Hinos</h2>
              <span id="planner-browser-count" class="count-badge">0</span>
            </div>
            <div class="planner-browser-filters">
              <input type="search" id="planner-browser-q" placeholder="Buscar título, número, tema...">
              <div class="planner-browser-row">
                <select id="planner-browser-hymnal">
                  <option value="">Todos os hinários</option>
                  <% (hymnals || []).forEach(function(hy) { %>
                    <option value="<%= hy.code %>"><%= hy.code %> — <%= hy.name %></option>
                  <% }); %>
                </select>
                <select id="planner-browser-theme">
                  <option value="">Todos os temas</option>
                  <% (themes || []).forEach(function(t) { %>
                    <option value="<%= t.id %>"><%= t.name %></option>
                  <% }); %>
                </select>
              </div>
            </div>
            <div id="planner-browser-results" class="planner-browser-results"></div>
          </aside>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= service ? 'Salvar Alterações' : 'Salvar Culto' %></button>
          <a href="/cultos" class="btn btn-secondary">Cancelar</a>
        </div>

      </form>
    </div>
  </div>

  <script>
    var timers = {};
    var browserTimer = null;
    var activeSlot = 1;

    function initSlot(n, initial) {
      var searchEl   = document.getElementById('search-'   + n);
      var dropEl     = document.getElementById('dropdown-' + n);
      var clearEl    = document.getElementById('clear-'    + n);
      var slotEl = document.querySelector('.slot[data-slot="' + n + '"]');

      if (initial && initial.id) {
        selectHymn(n, initial);
      }

      if (slotEl) {
        slotEl.addEventListener('click', function() {
          setActiveSlot(n);
        });
      }

      searchEl.addEventListener('input', function() {
        clearTimeout(timers[n]);
        var q = searchEl.value.trim();
        if (q.length < 2) { dropEl.style.display = 'none'; return; }
        timers[n] = setTimeout(function() {
          fetch('/api/hinos?q=' + encodeURIComponent(q))
            .then(function(r) { return r.json(); })
            .then(function(results) {
              dropEl.innerHTML = '';
              if (!results.length) { dropEl.style.display = 'none'; return; }
              results.forEach(function(h) {
                var li = document.createElement('li');
                li.textContent = h.hymnal + ' ' + h.number + ' \u2014 ' + h.title + (h.english_title ? ' (' + h.english_title + ')' : '');
                li.addEventListener('mousedown', function(e) {
                  e.preventDefault();
                  selectHymn(n, h);
                  setActiveSlot(n);
                });
                dropEl.appendChild(li);
              });
              dropEl.style.display = 'block';
            });
        }, 250);
      });

      searchEl.addEventListener('blur', function() {
        setTimeout(function() { dropEl.style.display = 'none'; }, 150);
      });
      searchEl.addEventListener('focus', function() {
        setActiveSlot(n);
      });

      clearEl.addEventListener('click', function(e) {
        e.stopPropagation();
        clearSlot(n);
      });
    }

    function setActiveSlot(n) {
      activeSlot = n;
      document.querySelectorAll('.slot').forEach(function(el) {
        el.classList.remove('active');
      });
      var slotEl = document.querySelector('.slot[data-slot="' + n + '"]');
      if (slotEl) slotEl.classList.add('active');
    }

    function findNextEmptySlot() {
      for (var n = 1; n <= 5; n += 1) {
        if (!document.getElementById('hymn-id-' + n).value) return n;
      }
      return 0;
    }

    function selectHymn(n, h) {
      document.getElementById('hymn-id-'  + n).value = h.id;
      document.getElementById('search-'   + n).style.display = 'none';
      document.getElementById('dropdown-' + n).style.display = 'none';
      document.getElementById('selected-' + n).textContent   = h.hymnal + ' ' + h.number + ' \u2014 ' + h.title;
      document.getElementById('selected-' + n).style.display = 'inline';
      document.getElementById('clear-'    + n).style.display = 'inline-flex';
    }

    function clearSlot(n) {
      document.getElementById('hymn-id-'  + n).value = '';
      document.getElementById('search-'   + n).value = '';
      document.getElementById('search-'   + n).style.display = '';
      document.getElementById('dropdown-' + n).style.display = 'none';
      document.getElementById('selected-' + n).style.display = 'none';
      document.getElementById('selected-' + n).textContent   = '';
      document.getElementById('clear-'    + n).style.display = 'none';
      document.getElementById('search-'   + n).focus();
    }

    function renderBrowserRows(rows) {
      var wrap = document.getElementById('planner-browser-results');
      var count = document.getElementById('planner-browser-count');
      if (!wrap || !count) return;
      var list = Array.isArray(rows) ? rows : [];
      count.textContent = String(list.length);
      if (!list.length) {
        wrap.innerHTML = '<div class="empty-hint">Nenhum hino encontrado.</div>';
        return;
      }
      wrap.innerHTML = '';
      list.forEach(function(h) {
        var row = document.createElement('div');
        row.className = 'planner-hymn-row';
        var subtitle = h.themes ? ('<div class="planner-hymn-sub">' + h.themes + '</div>') : '';
        row.innerHTML = ''
          + '<div class="planner-hymn-main">'
          + '<div class="planner-hymn-title">' + h.hymnal + ' ' + h.number + ' \u2014 ' + h.title + '</div>'
          + subtitle
          + '</div>'
          + '<button type="button" class="btn btn-primary btn-sm planner-add-btn">Adicionar</button>';
        row.querySelector('.planner-add-btn').addEventListener('click', function() {
          addHymnFromBrowser(h);
        });
        wrap.appendChild(row);
      });
    }

    function addHymnFromBrowser(h) {
      var target = activeSlot;
      if (document.getElementById('hymn-id-' + target).value) {
        var nextEmpty = findNextEmptySlot();
        if (nextEmpty) target = nextEmpty;
      }
      if (!target) {
        alert('Os 5 slots já estão preenchidos. Remova um para adicionar outro hino.');
        return;
      }
      selectHymn(target, h);
      setActiveSlot(target);
      var next = findNextEmptySlot();
      if (next) setActiveSlot(next);
    }

    async function runBrowserSearch() {
      var qEl = document.getElementById('planner-browser-q');
      var hymnalEl = document.getElementById('planner-browser-hymnal');
      var themeEl = document.getElementById('planner-browser-theme');
      if (!qEl || !hymnalEl || !themeEl) return;
      var params = new URLSearchParams();
      var q = String(qEl.value || '').trim();
      var hymnal = String(hymnalEl.value || '').trim();
      var theme = String(themeEl.value || '').trim();
      if (q) params.set('q', q);
      if (hymnal) params.set('hymnal', hymnal);
      if (theme) params.set('theme', theme);
      params.set('limit', '120');
      var res = await fetch('/api/hinos/browser?' + params.toString());
      var rows = await res.json();
      renderBrowserRows(rows);
    }

    function queueBrowserSearch() {
      clearTimeout(browserTimer);
      browserTimer = setTimeout(function() {
        runBrowserSearch().catch(function() {});
      }, 220);
    }

    var initialSlots = <%- JSON.stringify(slots) %>;
    [1,2,3,4,5].forEach(function(n) {
      initSlot(n, initialSlots[n - 1]);
    });
    setActiveSlot(findNextEmptySlot() || 1);

    var baseTemplateSelect = document.getElementById('base-template-select');
    if (baseTemplateSelect) {
      baseTemplateSelect.addEventListener('change', function() {
        var selected = String(baseTemplateSelect.value || '').trim();
        var dateInput = document.getElementById('service_date');
        var date = dateInput ? String(dateInput.value || '').trim() : '';
        if (!selected) {
          window.location.href = date ? ('/cultos/novo?date=' + encodeURIComponent(date)) : '/cultos/novo';
          return;
        }
        var url = '/cultos/novo?base=' + encodeURIComponent(selected);
        if (date) url += '&date=' + encodeURIComponent(date);
        window.location.href = url;
      });
    }

    var browserQEl = document.getElementById('planner-browser-q');
    var browserHymnalEl = document.getElementById('planner-browser-hymnal');
    var browserThemeEl = document.getElementById('planner-browser-theme');
    if (browserQEl) browserQEl.addEventListener('input', queueBrowserSearch);
    if (browserHymnalEl) browserHymnalEl.addEventListener('change', queueBrowserSearch);
    if (browserThemeEl) browserThemeEl.addEventListener('change', queueBrowserSearch);
    runBrowserSearch().catch(function() {});
  </script>
</body>
</html>
